{
    "manifest_version": 3,
    "name": "window.ml",
    "version": "1.0",
    "permissions": ["scripting", "activeTab", "storage"],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_title": "window.ml"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js", "sidebar.js"]
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["injected.js", "sidebar.html", "sidebar.css"],
        "matches": ["<all_urls>"]
      }
    ]
  }
